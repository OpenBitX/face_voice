# ─── Cartesia TTS（唯一 TTS 后端，付费）─────────────────────────────
# 在 https://play.cartesia.ai/keys 创建 API Key
# 下面为占位符，本地开发请改成你的真实 key（勿把含真实密钥的改动再 push，GitHub 会拦截）
CARTESIA_API_KEY=PASTE_YOUR_CARTESIA_API_KEY

# 可选：默认发音人 voice id。完整发音人库见 https://play.cartesia.ai/voices
CARTESIA_VOICE_ID=f786b574-daa5-4673-aa0c-cbe3e8534c02

# 可选：语言（zh / en / ja / fr / de / es / pt / ko / hi / it ...）
CARTESIA_LANGUAGE=zh

# 可选：模型（sonic-2 / sonic-3）
CARTESIA_MODEL=sonic-2

# ─── 可选：Replicate（高精度 Wav2Lip 唇形同步）────────────────────────
# 去 https://replicate.com/account/api-tokens 获取；不需要高精度唇形可留空
REPLICATE_API_TOKEN=
