# 复制本文件为 .env 并填入你的 key
FISH_API_KEY=ce2f03ff44a84d09ad00dc9b39781423

# 可选：指定 Fish Audio 的声音 ID（从 https://fish.audio/zh-CN/ 挑一个 funny 的中文声音，点进去 URL 末尾那段就是 reference_id）
# 留空则用默认声音
FISH_REFERENCE_ID=

# s1 质量高 / s1-mini 速度快 / speech-1.6 兼容旧模型
FISH_MODEL=s1

# 可选：Replicate token，用来调用高精度 Wav2Lip 模型
# 去 https://replicate.com/account/api-tokens 获取
REPLICATE_API_TOKEN=

# 可选：Edge TTS 默认声音（默认 zh-CN-YunxiNeural 云希）
EDGE_VOICE=zh-CN-YunxiNeural
